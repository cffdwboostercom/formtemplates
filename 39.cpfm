,{"form_identifier":"","name":"fieldname20","fieldlayout":"default","shortlabel":"","index":13,"ftype":"fPageBreak","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Page Break","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname21","fieldlayout":"default","shortlabel":"","index":14,"ftype":"fSectionBreak","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{"font-size":"2.3em"}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Results","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname15","fieldlayout":"default","shortlabel":"","index":15,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname16","fieldname17","fieldname18","fieldname19"],"columns":1,"rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname16","fieldlayout":"default","shortlabel":"","index":16,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Calories Per Day","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"medium","eq":"(function(){\n\tlet age \t= fieldname3,\n\t\theight \t= SUM(fieldname10, fieldname5*30.48, fieldname6*2.54),\n\t\tweight \t= SUM(fieldname11, fieldname7/2.2),\n\t\tgender\t= fieldname2,\n\t\tactivity= fieldname12,\n\t\tgoal\t= fieldname14,\n\t\tbmr_sys\t= fieldname4,\n\t\tcarbs_field \t= getField(fieldname17|n),\n\t\tprotein_field \t= getField(fieldname18|n),\n\t\tfat_field \t\t= getField(fieldname19|n),\n\t\tbmr, calories, protein, fat, carbs, total;\n\t\n\tif( ! AND(age, height, weight) ) {\n\t\tcarbs_field.setVal('');\n\t\tprotein_field.setVal('');\n\t\tfat_field.setVal('');\n\t\treturn '';\n\t};\n\t\n\tif ( bmr_sys == 'mifflin' )\t{\n\t\tbmr = IF(gender == 'male', 10 * weight + 6.25 * height - 5 * age + 5, 10 * weight + 6.25 * height - 5 * age - 161);\n\t} else {\n\t\tbmr = IF(gender == 'male', 88.362 + (13.397 * weight) + (4.799 * height) - (5.677 * age), 447.593 + (9.247 * weight) + (3.098 * height) - (4.330 * age));\n\t}\n\n\tswitch (activity) {\n\t\tcase 'sedentary':\n\t\t\tcalories = bmr * 1.2;\n\t\tbreak;\n\t\tcase 'lightly':\n\t\t\tcalories = bmr * 1.375;\n\t\tbreak;\n\t\tcase 'moderately':\n\t\t\tcalories = bmr * 1.55;\n\t\tbreak;\n\t\tcase 'very':\n\t\t\tcalories = bmr * 1.725;\n\t\tbreak;\n\t\tcase 'extra':\n\t\t\tcalories = bmr * 1.9;\n\t\tbreak;\n\t}\n\t\n\tswitch (goal) {\n\t\tcase 'lose':\n\t\t\tcalories -= 500;\n\t\tbreak;\n\t\tcase 'gain':\n\t\t\tcalories += 500;\n\t\tbreak;\n\t}\n\t\n\tprotein = weight * 2.2;\n\tfat = calories * 0.25 / 9;\n\tcarbs = (calories - (protein * 4 + fat * 9)) / 4;\n\t\n\ttotal = SUM(protein, fat, carbs);\n\t\n\tprotein = CONCATENATE( ROUND(protein), 'g ', ROUND(protein/total*100), '%' );\n\tfat \t= CONCATENATE( ROUND(fat), 'g ', ROUND(fat/total*100), '%' );\n\tcarbs \t= CONCATENATE( ROUND(carbs), 'g ', ROUND(carbs/total*100), '%' );\n\t\n\tcarbs_field.setVal(carbs);\n\tprotein_field.setVal(protein);\n\tfat_field.setVal(fat);\n\t\n\treturn ROUND(calories);\n  \n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname15"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname17","fieldlayout":"default","shortlabel":"","index":17,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Carbohydrate","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"medium","eq":"","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname15"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname18","fieldlayout":"default","shortlabel":"","index":18,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Protein","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"medium","eq":"","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname15"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname19","fieldlayout":"default","shortlabel":"","index":19,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":