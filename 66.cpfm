[[{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"filter-container","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname2","fieldname3"],"columns":1,"rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"ftext","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Enter the search term","autocomplete":"off","predefined":"","predefinedClick":false,"required":false,"exclude":false,"accept_html":false,"readonly":false,"size":"large","minlength":"","maxlength":"","equalTo":"","regExp":"","regExpMssg":"","fBuild":{},"parent":"fieldname1"},{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fButton","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"button":{"label":"Button","rules":{}},"button_hover":{"label":"Button hover","rules":{}}}},"sType":"button","sValue":"SEARCH","sOnclick":"EVALEQUATION('fieldname6', this.form);","sOnmousedown":"","sLoading":false,"sMultipage":false,"fBuild":{},"parent":"fieldname1"},{"form_identifier":"","name":"fieldname5","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","allowscript":0,"fcontent":"<div class=\"items-container\" data-cff-field=\"fieldname6\"></div>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Auxiliary","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"large","eq":"(function(){\n    async function fetchMetadata( term, callback ) {\n\t\tconst response = await fetch(`https://archive.org/advancedsearch.php?q=${term}&fl[]=title&fl[]=creator&fl[]=description&fl[]=date&fl[]=publisher&output=json`);\n\t\tconst data = await response.json();\n\t\tconst results = data.response.docs;\n\t\tlet output = '';\n\t\tif(! results.length) output = '<div class=\"error\">No items match the terms you entered.</div>';\n\t\tlet l = results.length;\n\t\tlet c = 0;\n\t\toutput += `<div class=\"result-stats\">${l} results</div>`;\n\t\toutput += `<div class=\"items-page active-page\">`;\n\t\tresults.forEach(item => {\n\t\t\tif( c && ! (c%10) ) output += `</div><div class=\"items-page\">`;\n\t\t\tc++;\n\t\t\toutput += `<div class=\"metadata-item\">\n                    <strong>Title:</strong> ${item.title ? item.title : 'N/A'}<br>\n                    <strong>Creator:</strong> ${item.creator ? item.creator : 'N/A'}<br>\n                    <strong>Description:</strong> ${item.description ? item.description : 'N/A'}<br>\n                    <strong>Date:</strong> ${item.date ? item.date : 'N/A'}<br>\n                    <strong>Publisher:</strong> ${item.publisher ? item.publisher : 'N/A'}\n\t\t\t\t\t</div>`;\n\t\t});\n\t\toutput += `</div><div class=\"items-pagination\">`;\n\t\tfor( let i = 0, h = CEIL(l/10); i < h; i++ ) {\n\t\t\toutput += `<span class=\"page-link ${i == 0 ? 'active-page-link' : ''}\" data-page=\"${i}\">${i+1}</span>`;\n\t\t}\n\t\toutput += `</div>`;\n\t\tcallback( output );\n\t}\n    let term = fieldname2|r;\n    if (!term) return '<div class=\"error\">Enter a search term.</div>';\t\n    return cffProxy(fetchMetadata, term);\n})()    ","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":false,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname7","fieldlayout":"default","shortlabel":"","index":5,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"Events","allowscript":1,"fcontent":"<script>\nfbuilderjQuery(document).on('click', '.page-link', function(){\n    let e = fbuilderjQuery(this);\n    let p = e.attr('data-page');\n    fbuilderjQuery('.items-page').removeClass('active-page');\n    fbuilderjQuery('.items-page:eq('+p+')').addClass('active-page');\n\tfbuilderjQuery('.page-link').removeClass('active-page-link');\n\te.addClass('active-page-link');\n});\n</script>","fBuild":{},"parent":""}],[{"title":"Archive.org","titletag":"H2","textalign":"center","headertextcolor":"","description":"Search for metadata in Archive.org.","formlayout":"top_aligned","formtemplate":"cp_cff_13","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .filter-container>div{display:flex;align-items:flex-end;}\n#fbuilder .filter-container>div .fields:first-child{flex-grow:1;}\n#fbuilder .items-container .metadata-item{margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid #dadada;}\n#fbuilder .items-container .metadata-item strong{font-weight:500;}\n#fbuilder .items-container .result-stats{border-bottom:1px solid #dadada;text-align:center;margin-bottom:20px;font-style:italic;}\n#fbuilder .items-container .items-page{display:none;}\n#fbuilder .items-container .items-page.active-page{display:block;}\n#fbuilder .items-container .items-pagination{text-align:center;}\n#fbuilder .items-container .items-pagination .page-link{display:inline-block;min-width:36px;min-height:36px;border:1px solid #dadada;margin:0 5px;padding:5px;cursor:pointer;}\n#fbuilder .items-container .items-pagination .page-link.active-page-link{background:#dadada;font-weight:500;}","request_cost":"fieldname2","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}}}}}]]