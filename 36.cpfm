":[""]}],"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Total  value","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","accept_html":true,"eq":"(function(){\n    let rate = fieldname2/100,\n        monthly_rate = rate/12,\n        monthly_payment = fieldname1,\n        payments = fieldname3*12,\n        total = 0,\n        list_a = [],\n        list_b = [],\n        labels = [];\n\n    for(let i = 0; i < payments; i++) {\n        total += monthly_payment;\n        total += total * monthly_rate;\n        if((i+1)%12 == 0) {\n            labels.push(CEIL(i/12)+(labels.length ? ' Years' : ' Year') );\n            list_a.push((i+1)*monthly_payment);\n            list_b.push(total);\n        }\n    }\n    \n    CFFCHART('investment-chart', {\n        type:'bar',\n        data:{\n            labels: labels,\n            datasets:[\n                {\n                    data:list_a, \n                    label: 'Total invested',\n                    backgroundColor: 'rgba(54, 162, 235, 1)',\n                    borderColor: 'rgba(54, 162, 235, 1)',\n                    borderWidth: 1\n                },\n                {\n                    data:list_b, \n                    label: 'Gains', \n                    backgroundColor: 'rgba(255, 99, 132, 1)',\n                    borderColor: 'rgba(255, 99, 132, 1)',\n                    borderWidth: 1 \n                },                \n            ]\n        },\n        options: {\n            scales: {\n                x: {stacked: true,},\n            }\n        }\n    });\n    return PREC(total, 2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimals