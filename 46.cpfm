nstructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<div class=\"cff-ratio\" data-cff-field=\"fieldname10\"></div>\n<div class=\"cff-shape\" data-cff-field=\"fieldname12\"></div>\n<div class=\"cff-risk\" data-cff-field=\"fieldname13\"></div>\n<div class=\"cff-ideal\" data-cff-field=\"fieldname14\"></div>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname10","fieldlayout":"default","shortlabel":"","index":9,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Hip to Waist Ratio","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n  let hip     = fieldname7, \n      waist   = fieldname8;\n  \n  if (OR(NOT(hip), NOT(waist))) return '';\n  if (OR(hip <= 0, waist <= 0)) return 'Measurements must be positive';\n  return PREC(waist / hip, 2, true);\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname12","fieldlayout":"default","shortlabel":"","index":10,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Shape","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n  let ratio = fieldname10;\n  if (fieldname10) {\n    /* Shape */\n    if (ratio <= 0.9) return 'Pear-shaped';\n    if (ratio <= 1) return 'Avocado-shaped';\n    return 'Apple-shaped';\n  }\n\n  return '';\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname13","fieldlayout":"default","shortlabel":"","index":11,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Risk","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n  let ratio   = fieldname10, \n      gender  = fieldname5;\n  \n  if ( ! ratio) return '';\n  \n  /* Risk */\n  if ( 'male' == gender ) {\n    if (ratio <= 0.95) return 'Low health risk';\n    if (ratio <= 1) return 'Moderate health risk';\n    return 'High health risk';\n  } else {\n    if (ratio <= 0.8) return 'Low health risk';\n    if (ratio <= 0.84) return 'Moderate health risk';\n    return 'High health risk';\n  }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname14","fieldlayout":"default","shortlabel":"","index":12,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Ideal range","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n  if ( ! fieldname10 ) return '';\n  if ( 'male' == fieldname5 ) {\n    return 'Ideal range 0.9-1.0';\n  } else {\n    return 'Ideal range 0.7-0.8';\n  }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""}],[{"title":"Hip-to-Waist Ratio","description":"The Hip to Waist Ratio (HWR) is an essential indicator of the body’s fat distribution and overall health.<br>It’s calculated by dividing the waist measurement by the hip measurement.","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname5","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .cff-ratio{text-align:center;font-size:3em;font-weight:700;}\n#fbuilder .cff-shape,\n#fbuilder .cff-risk,\n#fbuilder .cff-ideal{text-align:center;font-size:1.3em;margin-bottom:20px;}#fbuilder .captcha *{text-align:center;}","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{"margin-left":"50%","transform":"translatex(-50%)"}},"buttons_hover":{"label":"Form context buttons hover","rules":{}}}}}]]