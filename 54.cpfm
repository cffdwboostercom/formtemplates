fBuild":{},"parent":"fieldname1"},{"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fnumber","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"spinner_left":{"label":"Left spinner","rules":{}},"spinner_right":{"label":"Right spinner","rules":{}}}},"title":"Age (in months)","predefined":"","predefinedClick":false,"required":true,"exclude":false,"readonly":false,"numberpad":false,"spinner":false,"size":"large","prefix":"","postfix":"cm","thousandSeparator":"","decimalSymbol":".","min":"","max":"","step":"","formatDynamically":true,"dformat":"digits","formats":["digits","number","percent"],"fBuild":{},"parent":"fieldname1"},{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"dropdown":{"label":"Dropdown","rules":{}}}},"title":"Gender","size":"large","required":false,"exclude":false,"toSubmit":"text","merge":0,"choiceSelected":"","select2":false,"multiple":false,"first_choice":false,"first_choice_text":"","vChoices":1,"showDep":false,"choices":["Male","Female"],"optgroup":[false,false],"choicesVal":["male","female"],"choicesDep":[[],[]],"fBuild":{},"parent":"fieldname1"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname4","fieldlayout":"default","shortlabel":"","index":5,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Percentile","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    const maleData = [\n        [0, 46.1, 49.9, 53.7],\n        [3, 58.0, 61.4, 64.8],\n        [6, 63.8, 67.6, 71.4],\n        [12, 71.0, 75.7, 80.4],\n        [24, 81.7, 87.1, 92.5],\n        [36, 89.4, 95.4, 101.4],\n        /* Add more data points as needed */\n    ];\n\n    const femaleData = [\n        [0, 45.4, 49.1, 52.8],\n        [3, 56.4, 59.8, 63.2],\n        [6, 61.8, 65.7, 69.6],\n        [12, 68.9, 73.8, 78.7],\n        [24, 80.0, 85.7, 91.4],\n        [36, 87.4, 93.9, 100.4],\n        /* Add more data points as needed */\n    ];\n\n    const data = fieldname3 == 'male' ? maleData : femaleData;\n    const ageMonths = fieldname6;\n    const heightCm = fieldname5;\n    \n    if( OR(ageMonths <=0, heightCm <= 0 ) ) return '';\n    \n    /* Find the closest age in the data */\n    let closestAgeIndex = 0;\n    let smallestAgeDiff = Infinity;\n    for (let i = 0; i < data.length; i++) {\n        const ageDiff = Math.abs(data[i][0] - ageMonths);\n        if (ageDiff < smallestAgeDiff) {\n            smallestAgeDiff = ageDiff;\n            closestAgeIndex = i;\n        }\n    }\n\n    const [_, p3, p50, p97] = data[closestAgeIndex];\n\n    // Calculate percentile using linear interpolation\n    let percentile;\n    \n    if (heightCm <= p3) {\n        percentile = 3 * (heightCm / p3);\n    } else if (heightCm <= p50) {\n        percentile = 3 + (47 * (heightCm - p3)) / (p50 - p3);\n    } else if (heightCm <= p97) {\n        percentile = 50 + (47 * (heightCm - p50)) / (p97 - p50);\n    } else {\n        percentile = 97 + (3 * (heightCm - p97)) / (p97 - p50);\n    }\n\n    let result = PREC(percentile, 1, true);    \n    return IF(result == parseInt(result), parseInt(result), result);\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname8"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname7","fieldlayout":"default","shortlabel":"","index":6,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Deviation","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"IF( fieldname4, PREC(fieldname4 - 50, 1, true), '' );","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname8"}],[{"title":"Percentile Deviation","description":"Calculate the percentile deviation of a baby's height based on their age in months.","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname5","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"l