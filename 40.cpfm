[[{"list":{"json":{"title":"JSON","jsonData":{"source":""}},"recordset":{"title":"Recordset","recordsetData":{"recordset":"","value":"","text":"","where":""}},"database":{"title":"Database","databaseData":{"connection":"structure","dns":"","host":"","engine":"mysql","user":"","pass":"","database":""},"queryData":{"active":"query","query":"SELECT CONCAT('<a href=\"mailto:',pm.meta_value,'\">',pm.meta_value,'</a>') AS buyer_email, SUM(oim.meta_value) AS products_purchased, ROUND(SUM(om.meta_value),2) AS total_amount FROM {wpdb.prefix}posts p JOIN {wpdb.prefix}postmeta pm ON p.ID = pm.post_id JOIN {wpdb.prefix}woocommerce_order_items oi ON p.ID = oi.order_id JOIN {wpdb.prefix}woocommerce_order_itemmeta oim ON oi.order_item_id = oim.order_item_id JOIN {wpdb.prefix}postmeta om ON p.ID = om.post_id WHERE p.post_type = 'shop_order' AND p.post_status = 'wc-completed' AND pm.meta_key = '_billing_email' AND oim.meta_key = '_qty' AND om.meta_key = '_order_total' GROUP BY pm.meta_value ORDER BY total_amount DESC;","value":"","text":"","distinct":1,"table":"","where":"","orderby":"","limit":""}},"messages":{"title":"Forms submissions","messagesData":{"forms":"","submissions":"","logged":0,"paid":0,"unpaid":0,"fields":"","from":"","to":"","limit":"","conditions":""}},"server":{"title":"Server Side Equations","serverData":{"equation_name":"","parameters":""}},"acf":{"title":"Advanced Custom Fields","acfData":{"field_name":"","read_from":"post","src_id":""}},"csv":{"title":"CSV","csvData":{"text":0,"value":0,"file":"","type":"local","where":"","fields":[],"headline":false,"delimiter":"character","character":",","rows":[]}},"posttype":{"title":"Post Type","posttypeData":{"posttype":"","value":"ID","text":"post_title","last":"","id":""}},"taxonomy":{"title":"Taxonomy","taxonomyData":{"taxonomy":"","value":"term_id","text":"name","id":"","slug":""}},"user":{"title":"User Data","userData":{"logged":false,"text":"user_nicename","value":"ID","id":"","login":""}}},"isDataSource":true,"act