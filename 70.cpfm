[[{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fpassword","userhelp":"<div data-cff-field=\"fieldname3\" class=\"strength-indicator\"></div>","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Password","predefined":"","predefinedClick":false,"required":false,"exclude":false,"store":"no","unmaskedonfocus":true,"size":"large","minlength":"","maxlength":"","lowercase":false,"uppercase":false,"digit":false,"symbol":false,"equalTo":"","regExp":"","regExpMssg":"","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fpassword","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Repeat Password","predefined":"","predefinedClick":false,"required":false,"exclude":false,"store":"no","unmaskedonfocus":true,"size":"large","minlength":"","maxlength":"","lowercase":false,"uppercase":false,"digit":false,"symbol":false,"equalTo":"fieldname1","regExp":"","regExpMssg":"","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":true,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Password checking","_developerNotes":"","predefined":"","required":false,"exclude":true,"accept_html":false,"size":"large","eq":"(function(){\n    function getColor(score) {\n        switch (score) {\n            case 1: return \"#e74c3c\"; /* red */\n            case 2: return \"#e67e22\"; /* orange */\n            case 3: return \"#f1c40f\"; /* yellow */\n            case 4: return \"#2ecc71\"; /* green */\n            case 5: return \"#27ae60\"; /* darker green */\n            default: return \"#ddd\";\n        }\n    };\n\n    let pwd = fieldname1|r;\n    let score = 0;\n    let bars = '';\n    if (pwd.length >= 8) score++;\n    if (/[a-z]/.test(pwd) && /[A-Z]/.test(pwd)) score++;\n    if (/\\d/.test(pwd)) score++;\n    if (/[\\!\\@\\#\\$\\%\\^\\&\\*\\(\\)\\_\\+\\-\\=\\[\\]\\{\\}\\;\\'\\\"\\\\\\|\\,\\.\\<\\>\\/\\?]/.test(pwd)) score++;\n    if (pwd.length >= 12) score++; /* Bonus for extra length */\n\n    for(let i = 0; i < 5; i++) {\n        bars += '<div class=\"strength-bar\" style=\"background:'+(i<score?getColor(score):'#ddd')+';\"></div>';\n    }\n\n    return bars;\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"fBuild":{},"parent":""}],[{"title":"Password Strength Checker","titletag":"H2","textalign":"default","headertextcolor":"","description":"Checks password strength using a color-coded system.","formlayout":"top_aligned","formtemplate":"cp_cff_13","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .strength-indicator {\n\tdisplay: flex;\n  margin-top: 8px;\n  gap: 4px;\n}\n\n#fbuilder .strength-bar {\n\twidth: 20%;\n  height: 8px;\n  background: #ddd;\n  border-radius: 4px;\n  transition: background 0.3s;\n}","request_cost":"fieldname3","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}},"error_bubble":{"label":"Error bubbles","rules":{}},"error_bubble_arrow":{"label":"Error bubble arrow","rules":{"border-bottom-color":""},"restrict":true}}}}]]