[[{"form_identifier":"","name":"fieldname1","shortlabel":"","index":0,"ftype":"fcurrency","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Principal or Start Amount","predefined":"4000","predefinedClick":false,"required":false,"exclude":false,"readonly":false,"numberpad":false,"size":"large","currencySymbol":"$","currencyText":"","thousandSeparator":",","centSeparator":".","noCents":false,"min":"","max":"","formatDynamically":true,"twoDecimals":true,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","shortlabel":"","index":1,"ftype":"fnumber","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Annual Interest Rate","predefined":"5","predefinedClick":false,"required":false,"exclude":false,"readonly":false,"numberpad":false,"size":"large","thousandSeparator":",","decimalSymbol":".","min":"","max":"","formatDynamically":true,"dformat":"percent","formats":["digits","number","percent"],"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname3","shortlabel":"","index":2,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Compound Frequency","size":"large","required":false,"exclude":false,"toSubmit":"text","merge":0,"choiceSelected":"Monthly (12) - 12","select2":false,"multiple":false,"vChoices":1,"showDep":false,"choices":["Annually (1)","Semi-Annually (2)","Quarterly (4)","Bi-Monthly (6)","Monthly (12)","Semi-Monthly (24)","Bi-Weekly (26)","Weekly (52)","Daily (365)"],"optgroup":[false,false,false,false,false,false,false,false,false],"choicesVal":["1","2","4","6","12","24","26","52","365"],"choicesDep":[[],[],[],[],[],[],[],[],[]],"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname4","shortlabel":"","index":3,"ftype":"fnumber","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Years of Growth","predefined":"10","predefinedClick":false,"required":false,"exclude":false,"readonly":false,"numberpad":false,"size":"large","thousandSeparator":"","decimalSymbol":".","min":"","max":"","formatDynamically":false,"dformat":"digits","formats":["digits","number","percent"],"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname5","shortlabel":"","index":4,"ftype":"fcurrency","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Payment","predefined":"","predefinedClick":false,"required":false,"exclude":false,"readonly":false,"numberpad":false,"size":"large","currencySymbol":"$","currencyText":"","thousandSeparator":",","centSeparator":".","noCents":false,"min":"","max":"","formatDynamically":true,"twoDecimals":true,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname6","shortlabel":"","index":5,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Payment Frequency","size":"large","required":false,"exclude":false,"toSubmit":"text","merge":0,"choiceSelected":"Monthly (12) - 12","select2":false,"multiple":false,"vChoices":1,"showDep":false,"choices":["Annually (1)","Semi-Annually (2)","Quarterly (4)","Bi-Monthly (6)","Monthly (12)","Semi-Monthly (24)","Bi-Weekly (26)","Weekly (52)","Daily (365)"],"optgroup":[false,false,false,false,false,false,false,false,false],"choicesVal":["1","2","4","6","12","24","26","52","365"],"choicesDep":[[],[],[],[],[],[],[],[],[]],"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname11","shortlabel":"","index":6,"ftype":"fButton","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","sType":"calculate","sValue":"Calculate","sOnclick":"","sOnmousedown":"","sLoading":true,"sMultipage":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname10","shortlabel":"","index":7,"ftype":"fSectionBreak","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Result","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname7","shortlabel":"","index":8,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Future Value","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    var due = 0,\n        A = fieldname5,   \/* Payment *\/\n        P = fieldname1,   \/* Start Amount *\/\n        r = fieldname2,   \/* Annual Interest Rate 5% *\/\n        n = fieldname3,   \/* Compound Frequency *\/\n        t = fieldname4,   \/* Years of Growth *\/\n        p = fieldname6,   \/* Payment Frequency *\/\n\n        rate = Math.pow(1+r\/n,n\/p)-1,\n        nper = p * t,\n        F = r ? (P+(due ? A : 0))*Math.pow(1+rate, nper) + A*( (Math.pow(1+rate,nper) - 1)\/rate ) - (due ? A : 0) : P+A*p*t;\n    return PREC(F,2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname8","shortlabel":"","index":9,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Total Payments","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    var A = fieldname5,   \/* Payment *\/\n        t = fieldname4,   \/* Years of Growth *\/\n        p = fieldname6,   \/* Payment Frequency *\/\n        nper = p * t,\n        Total_Payments = A*nper;\n        \n    return PREC(Total_Payments, 2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname9","shortlabel":"","index":10,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Total Interest","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    var P = fieldname1,   \/* Start Amount *\/\n        Total_Interest = fieldname7 - P - fieldname8;\n    return PREC(Total_Interest,2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""}],{"0":{"title":"Compound Interest Calculator (For savings and loans)","description":"Compound Interest refers to earning or paying interest on interest. Although it can apply to both savings and loans, it is easiest to understand when thinking about savings. After each compound period, the interest earned over that period is added to the principal so that the next calculation of interest includes the original principal plus the previously earned interest.","formlayout":"left_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname1","evalequations":0,"evalequationsevent":2,"loading_animation":0,"autocomplete":1,"persistence":0,"customstyles":"#fbuilder .cff-button-field{text-align:center;}\n#fbuilder .section_breaks label{display:block;text-align:center;font-size:2.5em !important;margin:20px 0 !important;border-bottom:1px solid #ccc;}","animate_form":0},"formid":"cp_calculatedfieldsf_pform_1","setCache":false,"cache":false}]