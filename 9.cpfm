,"parent":""},{"form_identifier":"","name":"fieldname7","shortlabel":"","index":7,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"hide","fcontent":"\u003Ch2\u003EAmortization Schedule\u003C\/h2\u003E\n\u003Cdiv class=\u0022amortization-schedule\u0022\u003E\u003C\/div\u003E","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname8","shortlabel":"","index":8,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Amortization Schedule","predefined":"","required":false,"exclude":false,"size":"medium","accept_html":true,"eq":"(function () {\n    var r = CALCULATEAMORTIZATION(fieldname1-fieldname2, fieldname3*12, fieldname4*100, DATEOBJ(fieldname5)),\n    str = '';\n\n    if (r.length) {\n        str = '\u003Ctable cellpadding=\u002210\u0022 \u003E';\n        str += '\u003Cthead\u003E';\n        str += '\u003Ctr\u003E';\n        str += '\u003Cth\u003EDate\u003C\/th\u003E';\n        str += '\u003Cth\u003EInterest\u003C\/th\u003E';\n        str += '\u003Cth\u003EPayment\u003C\/th\u003E';\n        str += '\u003Cth\u003EPayment to Interest\u003C\/th\u003E';\n        str += '\u003Cth\u003EPayment to Principle\u003C\/th\u003E';\n        str += '\u003Cth\u003EPrinciple\u003C\/th\u003E';\n        str += '\u003C\/tr\u003E';\n        str += '\u003C\/thead\u003E';\n        str += '\u003Ctbody\u003E';\n        for (var i = 0, h = r.length; i \u003C h; i++) {\n            str += '\u003Ctr\u003E';\n            str += '\u003Ctd\u003E' + GETDATETIMESTRING(new Date(r[i]['date']), 'mm\/dd\/yyyy') + '\u003C\/td\u003E';\n            str += '\u003Ctd\u003E' + NUMBERFORMAT(r[i]['interest'], 'USD') + '\u003C\/td\u003E';\n            str += '\u003Ctd\u003E' + NUMBERFORMAT(r[i]['payment'], 'USD') + '\u003C\/td\u003E';\n            str += '\u003Ctd\u003E' + NUMBERFORMAT(r[i]['paymentToInterest'], 'USD') + '\u003C\/td\u003E';\n            str += '\u003Ctd\u003E' + NUMBERFORMAT(r[i]['paymentToPrinciple'], 'USD') + '\u003C\/td\u003E';\n            str += '\u003Ctd\u003E' + NUMBERFORMAT(r[i]['principle'], 'USD') + '\u003C\/td\u003E';\n            str += '\u003C\/tr\u003E';\n        }\n        str += '\u003C\/tbody\u003E';\n        str += '\u003C\/table\u003E';\n    }\n    jQuery('.amortization-schedule').html(str);\n\treturn str;\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"hidefield":true,"fBuild":{},"parent":""}],{"0":{"title":"Mortgage Calculator Form","description":"The mortgage calculator uses the financial operations module to calculate the monthly payment and generate the amortization schedule.","formlayout":"left_aligned","request_cost":"fieldname1","formtemplate":"cp_cff_13","evalequations":0,"evalequationsevent":2,"autocomplete":1,"persistence":0,"customstyles":"#fbuilder .amortization-schedule table{width:100%;}\n#fbuilder .amortization-schedule th,\n#fbuilder .amortization-schedule td{text-align:center; border-bottom:1px solid #cfcfcf}","loading_animation":0,"animate_form":0},"formid":"cp_calculatedfieldsf_pform_1","setCache":false,"cache":false}]