       table += '<tr>'+\n            '<td>'+record['symbol']+'</td>'+\n            '<td>'+record['priceChange']+'</td>'+\n            '<td>'+record['priceChangePercent']+'</td>'+\n            '</tr>';\n        }\n        table += '</tbody></table>';\n    } \n    return table;\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname4","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Biance symbols list generator","_developerNotes":"","predefined":"","required":false,"exclude":true,"size":"large","accept_html":true,"eq":"(function(){\n    let field = getField(fieldname3|n);\n    if ( Array.isArray(biance_data) ) {\n        let symbols  = [];\n        for ( let i in biance_data ) {\n            symbols.push(biance_data[i]['symbol']);\n        }\n        field.setChoices({texts:symbols, values:symbols});\n    }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname7","fieldlayout":"default","shortlabel":"","index":5,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Biance symbol details","_developerNotes":"","predefined":"","required":false,"exclude":true,"size":"large","accept_html":true,"eq":"(function(){\n    if ( \n        Array.isArray(biance_data) &&\n        typeof row_symbol != 'undefined'\n    ) {\n        let details = '';\n        let labels = {\n            'symbol': 'Trading pair symbol',\n            'priceChange': 'Price change in the last 24 hours',\n            'priceChangePercent': 'Percentage price change in the last 24 hours',\n            'weightedAvgPrice': 'Weighted average price of all trades in the last 24 hours',\n            'prevClosePrice': 'Previous day\\'s closing price',\n            'lastPrice': 'Last traded price',\n            'openPrice': 'Opening price of the current day',\n            'highPrice': 'Highest price reached in the last 24 hours',\n            'lowPrice': 'Lowest price reached in the last 24 hours',\n            'volume': 'Total trading volume in the last 24 hours',\n            'quoteVolume': 'Total quote asset volume in the last 24 hours',\n            'openTime': 'Timestamp of the current day\\'s opening time',\n            'closeTime': 'Timestamp of the current day\\'s closing time',\n            'firstId': 'ID of the first trade in the last 24 hours',\n            'lastId': 'ID of the last trade in the last 24 hours',\n            'count': 'Number of trades in the last 24 hours'\n        };\n        for ( let i in biance_data ) {\n            if (biance_data[i]['symbol'] == row_symbol) {\n                let record = biance_data[i];\n                details += '<table>'+\n                '<thead>'+\n                '<tr><th colspan=\"2\">'+row_symbol+'</th></tr>'+\n                '</thead>'+\n                '<tbody>';\n                for( let j in labels ) {\n                    if ( j in record ) {\n                        details += '<tr><td>'+labels[j]+'</td><td>'+record[j]+'</td></tr>';\n                    }\n                }\n                details += '</tbody></table>';\n                break;\n            }\n        }\n        return details;\n    }    \n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":6,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<div data-cff-field=\"fieldname7\" class=\"symbol-table\"></div>","fBuild":{},"parent":"fieldname5"}],[{"title":"Biance Wall","description":"Real-time market data for all trading pairs on the <b>Binance</b> exchange.","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname1","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":".biance-table{max-height:500px;overflow:auto;}\n.biance-table table{width:100%;}\n.biance-table table thead th{padding:10px;position:sticky;top:0;background:#DADADA;}\n.biance-table table tbody td{cursor:pointer;padding:5px;}\n.biance-table table tbody tr:nth-child(even){background:#E9E9E9;}\n.biance-table table tbody td:not(:first-child){text-align:center;}\n\n/* Symbol Table */\n.symbol-table table{width:100%;border-collapse:collapse;}\n.symbol-table table tbody td:not(:first-child){text-align:right;}\n.symbol-table table tbody td{border-top:1px solid #afafaf;padding:5px}\n.symbol-table table tbody td:first-child{font-weight:600;}"}]]