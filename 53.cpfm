[[{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname2","fieldname3","fieldname4"],"columns":"3","rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fcurrency","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"spinner_left":{"label":"Left spinner","rules":{}},"spinner_right":{"label":"Right spinner","rules":{}}}},"title":"Gross Salary","predefined":"","predefinedClick":false,"required":true,"exclude":false,"readonly":false,"numberpad":false,"spinner":false,"size":"large","currencySymbol":"$","currencyText":"","thousandSeparator":",","centSeparator":".","noCents":false,"min":"","max":"","step":"","formatDynamically":true,"twoDecimals":true,"fBuild":{},"parent":"fieldname1"},{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"dropdown":{"label":"Dropdown","rules":{}}}},"title":"Country","size":"large","required":false,"exclude":false,"toSubmit":"text","merge":0,"choiceSelected":"","select2":false,"multiple":false,"first_choice":false,"first_choice_text":"","vChoices":1,"showDep":false,"choices":["USA","UK","Germany","Canada"],"optgroup":[false,false,false,false],"choicesVal":["us","uk","de","ca"],"choicesDep":[[],[],[],[]],"fBuild":{},"parent":"fieldname1"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname4","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Net Salary","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function() {\n    let netSalary, country = fieldname3, grossSalary = fieldname2;\n\t\n\tif ( NOT(grossSalary) ) return '';\n\t\n    switch (country) {\n        case 'us':\n            const federalTaxRate = 0.12;\n            const socialSecurityRate = 0.062;\n            const medicareRate = 0.0145;\n            const totalDeductions = grossSalary * (federalTaxRate + socialSecurityRate + medicareRate);\n            netSalary = grossSalary - totalDeductions;\n            break;\n\n        case 'uk':\n            const ukTaxRate = 0.20;\n            const nationalInsuranceRate = 0.12;\n            const ukDeductions = grossSalary * (ukTaxRate + nationalInsuranceRate);\n            netSalary = grossSalary - ukDeductions;\n            break;\n\n        case 'de':\n            const germanyTaxRate = 0.30;\n            const germanySocialSecurityRate = 0.20;\n            const germanyDeductions = grossSalary * (germanyTaxRate + germanySocialSecurityRate);\n            netSalary = grossSalary - germanyDeductions;\n            break;\n\n        case 'ca':\n            const canadaTaxRate = 0.15;\n            const canadaCPP = 0.05;\n            const canadaEI = 0.018;\n            const canadaDeductions = grossSalary * (canadaTaxRate + canadaCPP + canadaEI);\n            netSalary = grossSalary - canadaDeductions;\n            break;\n\n        default:\n            return 'Country not supported';\n    }\n\n    return PREC(netSalary, 2, true);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname1"}],[{"title":"Net Salary Calculator","description":"Calculate the net salary based on gross salary and country (Deductions are just an estimate, but you can modify them directly in the equation associated with the calculated field).","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname2","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}}}}}]]