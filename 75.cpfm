dex":12,"ftype":"fSectionBreak","userhelp":"Results based on the data entered above","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Comparison Results","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname14","fieldlayout":"default","shortlabel":"","index":13,"ftype":"fCalculated","userhelp":"Monthly payment for purchasing the car","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Purchase Monthly Payment","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { var loanAmount = fieldname1 - fieldname2; var monthlyRate = fieldname3 / 100 / 12; var payment = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, fieldname4)) / (Math.pow(1 + monthlyRate, fieldname4) - 1); return Math.round(payment * 100) / 100; })()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"toolbar":"default|mathematical","dformat":"number","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname15","fieldlayout":"default","shortlabel":"","index":14,"ftype":"fCalculated","userhelp":"Total cost of purchasing the car over the loan term","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Total Purchase Cost","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { var totalLoanPayments = fieldname14 * fieldname4; var downPayment = parseFloat(fieldname2); var maintenanceCost = (fieldname20 / 12) * fieldname4; var resaleValue = fieldname1 * fieldname11; return Math.round((totalLoanPayments + downPayment + maintenanceCost - resaleValue) * 100) / 100; })()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"toolbar":"default|mathematical","dformat":"number","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname16","fieldlayout":"default","shortlabel":"","index":15,"ftype":"fCalculated","userhelp":"Total cost of leasing the car over the lease term","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Total Lease Cost","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { var leasePayments = fieldname6 * fieldname8; var leaseDown = parseFloat(fieldname7); var mileageFactor = fieldname12 === 'high' ? 1200 : 0; return Math.round((leasePayments + leaseDown + mileageFactor) * 100) / 100; })()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"toolbar":"default|mathematical","dformat":"number","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname17","fieldlayout":"default","shortlabel":"","index":16,"ftype":"fCalculated","userhelp":"Monthly cost of purchasing (including depreciation)","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Purchase Monthly Cost (Adjusted)","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { return Math.round(fieldname15 / fieldname4 * 100) / 100; })()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"toolbar":"default|mathematical","dformat":"number","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname18","fieldlayout":"default","shortlabel":"","index":17,"ftype":"fCalculated","userhelp":"Monthly cost of leasing","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Lease Monthly Cost (Adjusted)","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { return Math.round(fieldname16 / fieldname8 * 100) / 100; })()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"validate":false,"toolbar":"default|mathematical","dformat":"number","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname19","fieldlayout":"default","shortlabel":"","index":18,"ftype":"fCalculated","userhelp":"The better option based on total cost","audiotutorial":"","userhelpTooltip":true,"tooltipIcon":true,"csslayout":"","hidefield":true,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Recommendation","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"medium","eq":"(function() { \n    var purchaseCostPerMonth = fieldname15 / fieldname4; \n    var leaseCostPerMonth = fieldname16 / fieldname8; \n    var diff = Math.abs(purchaseCostPerMonth - leaseCostPerMonth); \n    if (diff < 20) { \n        return 'Both options are very similar in cost. Consider other factors like flexibility and ownership preferences.'; \n    } else if (purchaseCostPerMonth < leaseCostPerMonth) { \n        return 'PURCHASE is better financially by ' + FORMAT(Math.round((leaseCostPerMonth - purchaseCostPerMonth) * fieldname8 * 100) / 100, {prefix:\"$\", groupingsymbol:\",\", decimalsymbol:\".\", currency:true}) + ' over the lease term.'; \n    } else { \n        return 'LEASE is better financially by ' + FORMAT(Math.round((purchaseCostPerMonth - leaseCostPerMonth) * fieldname4 * 100) / 100, {prefix:\"$\", groupingsymbol:\",\", decimalsymbol:\".\", currency:true}) + ' over the loan term.'; \n    } \n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":false,"noEvalIfManual":tru