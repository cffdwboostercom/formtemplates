erhelp":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Future Value","predefined":"","required":false,"exclude":false,"size":"large","accept_html":true,"eq":"(function(){\n    var due = 0,\n        A = fieldname5,   \/* Payment *\/\n        P = fieldname1,   \/* Start Amount *\/\n        r = fieldname2,   \/* Annual Interest Rate 5% *\/\n        n = fieldname3,   \/* Compound Frequency *\/\n        t = fieldname4,   \/* Years of Growth *\/\n        p = fieldname6,   \/* Payment Frequency *\/\n\n        rate = Math.pow(1+r\/n,n\/p)-1,\n        nper = p * t,\n        F = r?(P+(due ? A : 0))*Math.pow(1+rate, nper) + A*( (Math.pow(1+rate,nper) - 1)\/rate ) - (due ? A : 0):P+A*p*t;\n    return PREC(F,2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname8","shortlabel":"","index":9,"ftype":"fCalculated","userhelp":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Total Payments","predefined":"","required":false,"exclude":false,"size":"large","accept_html":true,"eq":"(function(){\n    var A = fieldname5,   \/* Payment *\/\n        t = fieldname4,   \/* Years of Growth *\/\n        p = fieldname6,   \/* Payment Frequency *\/\n        nper = p * t,\n        Total_Payments = A*nper;\n        \n    return PREC(Total_Payments, 2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname9","shortlabel":"","index":10,"ftype":"fCalculated","userhelp":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Total Interest","predefined":"","required":false,"exclude":false,"size":"large","accept_html":true,"eq":"(function(){\n    var P = fieldname1,   \/* Start Amount *\/\n        Total_Interest = fieldname7 - P - fieldname8;\n    return PREC(Total_Interest,2);\n})()","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"hidefield":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname12","shortlabel":"","index":11,"ftype":"fhtml","userhelp":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","fcontent":"\u003Ccanvas id=\u0022chart\u0022 style=\u0022width:500px;heigth:500px\u0022\u003E\u003C\/canvas\u003E","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname13","shortlabel":"","index":12,"ftype":"fCalculated","userhelp":"For chart generation","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","title":"Auxiliary","predefined":"","required":false,"exclude":true,"size":"large","accept_html":true,"eq":"(function(){\n    if(typeof CFFCHART != 'undefined')\n    {\n        var labels = [],\n            datasets = [\n                {label: 'Principal + Payments', data:[], borderColor: '#B8F4FF', fill: false},\n                {label: 'Balance', data:[], borderColor: '#CC759A', fill: false}\n            ],\n            principal_payments = [],\n            r = fieldname2,   \/* Annual Interest Rate 5% *\/\n            n = fieldname3,   \/* Compound Frequency *\/\n            t = fieldname4,   \/* Years of Growth *\/\n            p = fieldname6,   \/* Payment Frequency *\/\n            d = new Date(),\n            rate = Math.pow(1+r\/n,n\/p)-1;\n            \n\n        d.setDate(1);\n\n        for(var i = 0; i \u003C= p*t; i++)\n        {\n            labels.push(GETDATETIMESTRING(d, 'dd\/mm\/yyyy'));\n            datasets[0]['data'].push(fieldname1+i*fieldname5);\n            \n            if(i)\n            {\n                switch(p)\n                {\n                    case 1:   d.setFullYear(d.setFullYear()+1); break;\n                    case 2:   d.setMonth(d.getMonth()+6); break;\n                    case 4:   d.setMonth(d.getMonth()+3); break;\n                    case 6:   d.setMonth(d.getMonth()+2); break;\n                    case 12:  d.setMonth(d.getMonth()+1); break;\n                    case 24:  if(i%2 == 0) d = EOMONTH(d1, c\/2); else d.setDate(d.getDate()+14); break;\n                    case 26:  d.setDate(d.getDate()+14); break;\n                    case 52:  d.setDate(d.getDate()+7); break;\n                    case 365: d.setDate(d.getDate()+1); break;\n                }\n\n                datasets[1]['data'].push(\n                    datasets[1]['data'][i-1]+fieldname5+\n                    ((n == 365) ? \n                    datasets[1]['data'][ic-1]*(POW(1+rate, DATEDIFF(labels[i-1], labels[i], 'dd\/mm\/yyyy', 'd')['days'])-1 ) : \n                    datasets[1]['data'][i-1]*rate)\n                );\n            }\n            else\n            {\n                datasets[1]['data'].push(fieldname1);\n            }    \n        }\n\n        CFFCHART(\n            'chart',\n            {\n                type:'line',\n                data:{\n                    labels: labels,\n                    datasets: datasets\n                },\n                options:{\n                    tooltips: {\n\t\t\t\t        callbacks: {\n                            label: function(tooltipItem, data) {\n                                return FORMAT(PREC(tooltipItem.yLabel,2), {prefix:\u0022$\u0022, suffix:\u0022\u0022, groupingsymbol:\u0022,\u0022, decimalsymbol:\u0022.\u0022, currency:true});\n                            }\n\t\t\t\t        }\n                    }    \n\t\t\t    }\n            }\n        );\n    }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"hidefield":true,"fBuild":{},"parent":""}],{"0":{"title":"Compound Interest Calculator (For savings and loans)","description":"Compound Interest refers to earning or paying interest on interest. Although it can apply to both savings and loans, it is easiest to understand when thinking about savings. After each compound period, the interest earned over that period is added to the principal so that the next calculation of interest includes the original principal plus the previously earned interest.","formlayout":"left_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname1","evalequations":0,"evalequationsevent":2,"loading_animation":0,"autocomplete":1,"persistence":0,"customstyles":"#fbuilder .cff-button-field{text-align:center;}\n#fbuilder .section_breaks label{display:block;text-align:center;font-size:2.5em !important;margin:20px 0 !important;border-bottom:1px solid #ccc;}"},"formid":"cp_calculatedfieldsf_pform_1","setCache":false,"cache":false}]