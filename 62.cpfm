[[{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<div class=\"visitor-details\"></div>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Get visitor details","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":false,"size":"large","eq":"(function(){\n    return JSON.stringify(cffProxy(function(callback){\n        fbuilderjQuery.ajax({\n            url: 'https://get.geojs.io/v1/ip/geo.json',\n                dataType: 'json',\n                crossDomain: true,\n                success: function(result) {\n                    let summary = '';\n                    let end_line = '';\n                    for ( let i in result ) {\n                        summary += end_line + '<b>' + i + '</b>: ' + result[i];\n                        end_line = '<br />';\n                    }    \n                    fbuilderjQuery('.visitor-details').html( summary );\n                    callback(result);\n                }\n            });\n    }));\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true