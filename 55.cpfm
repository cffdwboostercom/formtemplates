"label":"AM/PM selector","rules":{}}}},"title":"Time B","predefined":"","predefinedClick":false,"size":"large","required":false,"exclude":false,"readonly":false,"disableKeyboardOnMobile":false,"dformat":"mm/dd/yyyy","dseparator":"/","tformat":"12","showDropdown":false,"dropdownRange":"-10:+10","minDate":"","maxDate":"","invalidDates":"","validDates":"","mondayFirstDay":false,"alwaysVisible":false,"minHour":0,"maxHour":23,"minMinute":0,"maxMinute":59,"stepHour":1,"stepMinute":1,"showDatepicker":false,"showTimepicker":true,"ariaHourLabel":"hours","ariaMinuteLabel":"minutes","ariaAMPMLabel":"am or pm","currentDate":0,"defaultDate":"","defaultTime":"","working_dates":[true,true,true,true,true,true,true],"formats":["mm/dd/yyyy","dd/mm/yyyy","yyyy/mm/dd","yyyy/dd/mm"],"separators":["/","-","."],"errorMssg":"","fBuild":{},"parent":"fieldname16"},{"form_identifier":"","name":"fieldname5","fieldlayout":"default","shortlabel":"","index":8,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"cff-result","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<b>Result:</b> <span data-cff-field=\"fieldname6\"></span>","fBuild":{},"parent":"fieldname15"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":9,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Dates difference","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    let diffObj = DATEDIFF(fieldname2, fieldname3, 'mm/dd/yyyy', fieldname4),\n        result = '';\n\n    if( 0 < diffObj['years'] ) {\n        result += diffObj['years']+' year(s)';\n    }\n\n    if( 0 < diffObj['months'] ) {\n        result += (result != '' ? ', ' : '')+diffObj['months']+' month(s)';\n    }\n\n    if( 0 < diffObj['days'] ) {\n        result += (result != '' ? ' and ' : '')+diffObj['days']+' day(s)';\n    }\n\n    if(result == '') {\n        result = 'No dates difference';\n    }\n    return result;\n\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":"fieldname15"},{"form_identifier":"","name":"fieldname12","fieldlayout":"default","shortlabel":"","index":10,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"cff-result","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<b>Result:</b> <span data-cff-field=\"fieldname13\"></span>","fBuild":{},"parent":"fieldname16"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname13","fieldlayout":"default","shortlabel":"","index":11,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Times difference","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    let diffObj = DATEDIFF(fieldname10, fieldname11, 'hh:ii', fieldname14),\n        result = '';\n\n    if( 0 < diffObj['hours'] ) {\n        result += diffObj['hours']+' hours(s)';\n    }\n\n    if( 0 < diffObj['minutes'] ) {\n        result += (result != '' ? ' and ' : '')+diffObj['minutes']+' minute(s)';\n    }\n\n    if( result == '' ) {\n        result = 'No times difference';\n    }    \n    \n    return result;\n\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":"fieldname16"}],[{"title":"Dates Difference","description":"It calculates the difference between two dates using the DATEDIFF operation.","formlayout":"top_aligned","formtemplate":"cp_cff_13","textalign":"center","customstyles":"#fbuilder .cff-result *{font-size:1.3em !important;text-align:center;}","titletag":"H2","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}}}}}]]