[[{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","allowscript":1,"fcontent":"<div data-cff-field=\"fieldname2\"></div>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Auxiliary","_developerNotes":"","predefined":"","required":false,"exclude":false,"accept_html":true,"size":"large","eq":"(function(){\n    function getPlaylist(callback) {\n        fbuilderjQuery.ajax({\n            url: 'https://openwhyd.org/adrien/?format=json',\n            dataType: 'jsonp',\n            crossDomain: true,\n            success: function(result) {\n                let output = '';\n                if ( Array.isArray(result ) ) {\n                    for ( let i in result ) {\n                        let item = result[i];\n                        try {\n                            if ( ! ( 'src' in item ) ) { continue; }\n                            output += '<div class=\"playlist-item\">';\n                            if ( 'img' in item && item['img'] ) {\n                                output += `<div class=\"playlist-item-cover\">\n                                <a href=\"${item.src.id}\" target=\"_blank\"><img src=\"${item.img}\"></a>\n                                </div>`;\n                            }\n                            output += '<div class=\"playlist-item-info\">';\n                            if ( 'name' in item && item['name'] ) {\n                                output += `<div class=\"playlist-item-name\">${item.name}</div>`;\n                            }\n                            output += `<div class=\"playlist-item-src\"><a href=\"${item.src.id}\" target=\"_blank\">${item.src.name}</a></div>\n                            </div></div>`;\n                        } catch (err){  console.log( err ); }\n                    }                   \n                } \n                callback(output);\n            }\n        });\n    };\n    return cffProxy(getPlaylist);\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""}],[{"title":"Openwhyd Playlist","titletag":"H2","textalign":"center","headertextcolor":"","description":"It loads the Adrien playlist (you can substitute the user in the calculated field equation).","formlayout":"top_aligned","formtemplate":"cp_cff_13","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .playlist-item{\n\tdisplay:flex;\n\tpadding:5px;\n\tmargin:0 0 15px 0;\n\tbackground:white;\n\tbox-shadow:0px 0px 2px 0px rgba(0,0,0,0.4);\n}\n#fbuilder .playlist-item-cover{margin-right:10px;position:relative;}\n#fbuilder .playlist-item-cover a{display: inline-block;line-height:0;}\n#fbuilder .playlist-item-cover a::after{\n\tcontent:\"\\25B6\";\n\tposition:absolute;\n\ttop:50%;\n\tleft:50%;\n\ttransform:translate(-50%,-50%);\n\tcolor:white;\n\tfont-size:32px;\n\ttext-shadow:0 0 1px black;\n\tcursor:pointer;\n}\n#fbuilder .playlist-item-name{font-weight:600;font-size:14px;}\n#fbuilder .playlist-item-src a{font-size:13px;color:#007cba;}\n#fbuilder .playlist-item-cover a:hover img{opacity:0.5;}\n#fbuilder .playlist-item-cover a:hover::after{color:black;text-shadow:0 0 1px white;}\n#fbuilder .playlist-item-src a:hover{color:#349ed3;}","request_cost":"fieldname2","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}}}}}]]