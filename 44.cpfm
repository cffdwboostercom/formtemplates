 tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<span class=\"cost-label\">Price:</span> <span class=\"cost-price\" data-cff-field=\"fieldname16\"></span><br> \n<span class=\"cost-label\">Price+VAT:</span> <span class=\"cost-price\" data-cff-field=\"fieldname17\"></span>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname16","fieldlayout":"default","shortlabel":"","index":17,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Cost","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    if(AND(fieldname4, fieldname6, fieldname8)){\n        /* Rooms cost = Nights number x Rooms x Room cost per night */\n        let result = fieldname8*fieldname4*fieldname10;\n\n        /* Breakfast = (Adult+Children) x Nights x Breakfast price */\n        result += SUM(fieldname6, fieldname7)*fieldname4*fieldname13;\n\n        /* Parking = Nights x Parking cost */\n        result += fieldname4*fieldname14;\n\n        /* Laundry = Every three days x Laundry cost */\n        result += CEIL(fieldname4/3)*fieldname15;\n\n        return PREC(result, 2, true);\n    }\n    return '';\n})()    ","min":"","max":"","suffix":"","prefix":"$","decimalsymbol":".","groupingsymbol":",","readonly":true,"currency":true,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname17","field