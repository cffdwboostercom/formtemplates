[[{"form_identifier":"","name":"fieldname6","fieldlayout":"top_aligned","shortlabel":"","index":0,"ftype":"ftext","userhelp":"Enter the search term for filtering the WooCommerce products.","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"cff-woocommerce-search-box","advanced":{"css":{"label":{"label":"Field label","rules":{"font-size":"2em","font-weight":"300"}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Search","autocomplete":"off","predefined":"","predefinedClick":false,"required":false,"exclude":false,"readonly":false,"size":"large","minlength":"","maxlength":"","equalTo":"","regExp":"","regExpMssg":"","fBuild":{},"parent":""},{"list":{"json":{"title":"JSON","jsonData":{"source":""}},"recordset":{"title":"Recordset","recordsetData":{"recordset":"","value":"","text":"","where":""}},"database":{"title":"Database","databaseData":{"connection":"structure","dns":"","host":"","engine":"mysql","user":"","pass":"","database":""},"queryData":{"active":"query","query":"SELECT posts.ID as id, posts.post_title as title, posts.post_excerpt as excerpt, posts.guid as url, post_meta.meta_value as price, picture_data.picture_path as picture FROM {wpdb.posts} as posts INNER JOIN {wpdb.postmeta} as post_meta ON (posts.ID = post_meta.post_id) LEFT JOIN ( SELECT post_meta3.meta_value as picture_path, post_meta2.post_id FROM {wpdb.postmeta} as post_meta2 INNER JOIN {wpdb.postmeta} as post_meta3 ON (post_meta2.meta_value = post_meta3.post_id AND post_meta2.meta_key = \"_thumbnail_id\" AND post_meta3.meta_key = \"_wp_attached_file\") ) as picture_data ON (posts.ID = picture_data.post_id) WHERE posts.post_status=\"publish\" AND posts.post_type=\"product\" AND post_meta.meta_key=\"_price\" AND ( post_title LIKE \"%<%fieldname6|r%>%\" OR post_content LIKE \"<%fieldname6|r%>\" OR post_excerpt LIKE \"<%fieldname6|r%>\" OR \"<%fieldname6|r%>\" = \"\")","value":"","text":"","distinct":1,"table":"","where":"","orderby":"","limit":""}},"messages":{"title":"Forms submissions","messagesData":{"forms":"","submissions":"","logged":0,"paid":0,"unpaid":0,"fields":"","from":"","to":"","limit":"","conditions":""}},"server":{"title":"Server Side Equations","serverData":{"equation_name":"","parameters":""}},"acf":{"title":"Advanced Custom Fields","acfData":{"field_name":"","read_from":"post","src_id":""}},"csv":{"title":"CSV","csvData":{"text":0,"value":0,"file":"","type":"local","where":"","fields":[],"headline":false,"delimiter":"character","character":",","rows":[]}},"posttype":{"title":"Post Type","posttypeData":{"posttype":"","value":"ID","text":"post_title","last":"","id":""}},"taxonomy":{"title":"Taxonomy","taxonomyData":{"taxonomy":"","value":"term_id","text":"name","id":"","slug":""}},"user":{"title":"User Data","userData":{"logged":false,"text":"user_nicename","value":"ID","id":"","login":""}}},"isDataSource":true,"active":"database","form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":1,"ftype":"frecordsetds","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"Get the products list","fBuild":{},"parent":""},{"list":{"json":{"title":"JSON","jsonData":{"source":""}},"recordset":{"title":"Recordset","recordsetData":{"recordset":"","value":"","text":"","where":""}},"database":{"title":"Database","databaseData":{"connection":"structure","dns":"","host":"","engine":"mysql","user":"","pass":"","database":""},"queryData":{"active":"query","query":"SELECT option_value as siteurl FROM {wpdb.options} WHERE option_name=\"siteurl\"","value":"","text":"","distinct":1,"table":"","where":"","orderby":"","limit":""}},"messages":{"title":"Forms submissions","messagesData":{"forms":"","submissions":"","logged":0,"paid":0,"unpaid":0,"fields":"","from":"","to":"","limit":"","conditions":""}},"server":{"title":"Server Side Equations","serverData":{"equation_name":"","parameters":""}},"acf":{"title":"Advanced Custom Fields","acfData":{"field_name":"","read_from":"post","src_id":""}},"csv":{"title":"CSV","csvData":{"text":0,"value":0,"file":"","type":"local","where":"","fields":[],"headline":false,"delimiter":"character","character":",","rows":[]}},"posttype":{"title":"Post Type","posttypeData":{"posttype":"","value":"ID","text":"post_title","last":"","id":""}},"taxonomy":{"title":"Taxonomy","taxonomyData":{"taxonomy":"","value":"term_id","text":"name","id":"","slug":""}},"user":{"title":"User Data","userData":{"logged":false,"text":"user_nicename","value":"ID","id":"","login":""}}},"isDataSource":true,"active":"database","form_identifier":"","name":"fieldname4","fieldlayout":"default","shortlabel":"","index":2,"ftype":"frecordsetds","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"Get the website's URL","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Products List","_developerNotes":"","predefined":"","required":false,"exclude":true,"size":"large","accept_html":true,"eq":"(function(){\nlet products = fieldname1, output = '', \n    siteurl  = fieldname4[0]['siteurl'],\n    imageurl = siteurl+'/wp-content/uploads/';\nfor ( let i in products ){\n    let product = products[i];\n\n    output += '<div class=\"cff-product-item\">'+\n        (product['picture'] ? '<div class=\"cff-product-image\"><a href=\"'+product['url']+'\" target=\"_blank\"><img src=\"'+imageurl+product['picture']+'\"></a></div>' : '')+\n        '<div class=\"cff-product-data\">'+\n            '<div class=\"cff-product-title\"><a href=\"'+product['url']+'\" target=\"_blank\">'+product['title']+'</a> <div class=\"cff-product-price\">($'+PREC(product['price'], 2)+')</div></div>'+\n            '<div class=\"cff-product-excerpt\">'+product['excerpt']+'</div>'+\n            '<div class=\"cff-product-buttons\"><input type=\"button\" value=\"add to cart\" onclick=\"window.open(\\''+siteurl+'?add-to-cart='+product['id']+'\\', \\'_blank\\');\" /></div>'+\n        '</div>'+\n    '</div>';\n}\nreturn output;\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<div data-cff-field=\"fieldname2\"></div>\n<script>\nfbuilderjQuery(document).on('formReady', function(){\nfbuilderjQuery(document).on('keyup', '[id*= \"fieldname6_\"]', function(){\nfbuilderjQuery(this).trigger('change');\t\n});\t\n});\t\n</script>","fBuild":{},"parent":""}],[{"title":"The form filters WooCommerce products based on search terms.","description":"","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname2","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .cff-product-item{border:1px solid #DDDDDD;padding:10px;margin-bottom:10px;display:flex;border-radius:5px;}\n#fbuilder .cff-product-item .cff-product-image{max-width:150px;box-sizing:border-box;}\n#fbuilder .cff-product-item .cff-product-image:not(:empty){padding-right:10px;}\n#fbuilder .cff-product-item .cff-product-image img{border-radius:5px;width:100%;box-sizing:border-box;border:3px solid #dadada;}\n#fbuilder .cff-product-item .cff-product-image img:hover{border-color:#6f696c;}\n#fbuilder .cff-product-item .cff-product-data{flex-grow:1;}\n#fbuilder .cff-product-item .cff-product-title a{font-size:1.5em;text-decoration:none;font-weight:300;color:#6f696c;\tdisplay:inline-block;}\n#fbuilder .cff-product-item .cff-product-title a:hover{color:#000000;}\n#fbuilder .cff-product-item .cff-product-price{font-size:1.5em;margin-bottom:10px;color:#6f696c;font-weight:300;\tdisplay:inline-block;}\n#fbuilder .cff-product-item .cff-product-excerpt{font-style:italic;font-size:14px;}\n#fbuilder .cff-product-item .cff-product-excerpt:not(:empty){margin-bottom:15px;}\n#fbuilder .cff-product-buttons{text-align:right;}\n#fbuilder .cff-product-buttons input[type=\"button\"]{border:0 !important;text-transform:uppercase;background-color:#6f696c !important;color:white;border-radius:5px !important;}\n#fbuilder .cff-product-buttons input[type=\"button\"]:hover{background-color:#333333 !important;}\n#fbuilder .cff-woocommerce-search-box{background:#F6F6F6;box-sizing:border-box;padding:10px !important;border-radius:5px;}\n#fbuilder .cff-woocommerce-search-box input[type=\"text\"]{border:1px solid #6f696c !important;margin-bottom:5px;border-radius:5px !important;}\n#fbuilder .cff-woocommerce-search-box input[type=\"text\"]:focus{outline:none !important;box-shadow:none !important;}\n\n@media screen AND (min-width:710px) {\n\t#fbuilder .cff-product-item{width:calc( 50% - 5px );float:left;}\n\t#fbuilder .cff-product-item:nth-child(odd){margin-right:10px;}\n}","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form title","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{"background":"#6f696c","border-color":"#6f696c","text-transform":"uppercase"}},"buttons_hover":{"label":"Form context buttons hover","rules":{"background":"#333333","border-color":"#333333"}}}}}]]