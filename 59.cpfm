[[{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"dropdown":{"label":"Dropdown","rules":{}}}},"title":"Currency Base","size":"large","required":false,"exclude":false,"toSubmit":"text","merge":0,"choiceSelected":"","select2":false,"multiple":false,"first_choice":false,"first_choice_text":"","vChoices":1,"showDep":false,"choices":["United State Dollar","Euro","Canadian Dollar"],"optgroup":[false,false,false],"choicesVal":["usd","eur","cad"],"choicesDep":[[],[],[]],"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<script>\ncoingecko_data = [];\nfbuilderjQuery(document).on('formReady', function () {\n\tlet $ = fbuilderjQuery;\n    function loadData(currency) {\n        $.ajax({\n            url: CONCATENATE('https://api.coingecko.com/api/v3/coins/markets?vs_currency=', currency),\n            dataType: 'json',\n            success: function (result) {\n                if (typeof result === 'object' && Array.isArray( result ) ) {\n                    coingecko_data = result;\n                    coingecko_data.sort((a, b) => a.market_cap_rank - b.market_cap_rank);\n                    EVALEQUATION('fieldname1');\n                }\n            }\n        });\n    };\n\t\n\t$(document).on('change', CONCATENATE('#',getField('fieldname3').name), function () {\n\t\tloadData(getField('fieldname3').val(false, true));\n\t});\n\tloadData(getField('fieldname3').val(false, true));\n});\n\nfbuilderjQuery(document).on('click', '.coingecko-table tbody tr', function () {\n    row_symbol = fbuilderjQuery(this).find('td:eq(0)').text();\n    EVALEQUATION('fieldname7');\n    SHOWFIELD('fieldname5');\n});\n</script>\n<div data-cff-field=\"fieldname1\" class=\"coingecko-table\"></div>","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname5","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fpopup","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"header":{"label":"Header area","rules":{"font-weight":"bold"}},"close":{"label":"Close button","rules":{}},"content":{"label":"Content area","rules":{}}}},"fields":["fieldname6"],"columns":1,"rearrange":0,"title":"Cryptocurrency Details","titletag":"P","_developerNotes":"","open_onload":false,"open_onclick":"","close_button":true,"modal":true,"dragging":false,"resizing":true,"position":"center","width":"80%","height":"360px","collapsed":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"CoinGecko table generator","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","accept_html":true,"eq":"(function(){\n    let table = '';\n    if ( Array.isArray(coingecko_data) ) {\n        table += '<table>'+\n        '<thead>'+\n        '<tr>'+\n        '<th>Symbol</th>'+\n        '<th>Name</th>'+\n        '<th>Image</th>'+\n        '<th>Rank</th>'+\n        '<th>Price (' + fieldname3|v + ')</th>'+\n        '<th>Price Percent Change Last 24 Hours</th>'+\n        '</tr>'+\n        '</thead>'+\n        '<tbody>';\n        for ( let i in coingecko_data ) {\n            let record = coingecko_data[i];\n            table += '<tr>'+\n            '<td>'+record['symbol']+'</td>'+\n            '<td>'+record['name']+'</td>'+\n            '<td><img src=\"'+record['image']+'\"></td>'+\n            '<td>'+record['market_cap_rank']+'</td>'+\n            '<td>'+record['current_price']+'</td>'+\n            '<td>'+record['price_change_percentage_24h']+'</td>'+\n            '</tr>';\n        }\n        table += '</tbody></table>';\n    } \n    return table;\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname7","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"CoinGecko symbol details","_developerNotes":"","predefined":"","required":false,"exclude":true,"size":"large","accept_html":true,"eq":"(function () {\n    if (\n        Array.isArray(coingecko_data) &&\n        typeof row_symbol != 'undefined') {\n        let details = '';\n        let labels = {\n            'id': 'Identifier',\n            'symbol': 'Symbol',\n            'name': 'Name',\n            'image': 'Image',\n            'current_price': 'Price('+fieldname3|v+')',\n            'market_cap': 'Total market capitalization',\n            'market_cap_rank': 'The ranking by market capitalization',\n            'fully_diluted_valuation': 'Fully diluted market capitalization',\n            'total_volume': 'Total trading volume',\n            'high_24h': 'Highest price in the last 24 hours',\n            'low_24h': 'Lowest price in the last 24 hours',\n            'price_change_percentage_24h': 'Percentage change in the price in the last 24 hours',\n            'price_change_percentage_7d': 'Percentage change in the price in the last 7 days',\n            'price_change_percentage_14d': 'Percentage change in the price in the last 14 days',\n            'price_change_percentage_30d': 'Percentage change in the price in the last 30 days',\n            'price_change_percentage_60d': 'Percentage change in the price in the last 60 days',\n            'price_change_percentage_200d': 'Percentage change in the price in the last 200 days',\n            'price_change_percentage_1y': 'Percentage change in the price in the last 1 year',\n            'market_cap_change_percentage_24h': 'Percentage change in the market capitalization in the last 24 hours',\n            'market_cap_change_percentage_7d': 'Percentage change in the market capitalization in the last 7 days',\n            'market_cap_change_percentage_14d': 'Percentage change in the market capitalization in the last 14 days',\n            'market_cap_change_percentage_30d': 'Percentage change in the market capitalization in the last 30 days',\n            'market_cap_change_percentage_60d': 'Percentage change in the market capitalization in the last 60 days',\n            'market_cap_change_percentage_200d': 'Percentage change in the market capitalization in the last 200 days',\n            'market_cap_change_percentage_1y': 'Percentage change in the market capitalization in the last 1 year',\n            'circulating_supply': 'Current circulating supply',\n            'total_supply': 'Total supply',\n            'max_supply': 'Maximum supply',\n            'ath': 'All-time high price',\n            'ath_change_percentage': 'Percentage change in the price of the cryptocurrency from its all-time high',\n            'ath_date': 'Date when the cryptocurrency reached its all-time high price',\n            'atl': 'All-time low price',\n            'atl_change_percentage': 'Percentage change in the price of the cryptocurrency from its all-time low',\n            'atl_date': 'Date when the cryptocurrency reached its all-time low price',\n            'roi': 'The return on investment for the cryptocurrency',\n            'last_updated': 'Timestamp of the last update to the cryptocurrency\\'s data'\n        };\n        for (let i in coingecko_data) {\n            if (coingecko_data[i]['symbol'] == row_symbol) {\n                let record = coingecko_data[i];\n                details += '<table>' +\n                '<thead>' +\n                '<tr><th colspan=\"2\">' + record['name'] + '</th></tr>' +\n                '</thead>' +\n                '<tbody>';\n                for (let j in labels) {\n                    if (j in record && record[j] != null) {\n                        let v = record[j];\n                        if (j == 'image') v = '<img src=\"'+v+'\" width=\"40px\" />';\n                        details += '<tr><td>' + labels[j] + '</td><td>' + v + '</td></tr>';\n                    }\n                }\n                details += '</tbody></table>';\n                break;\n            }\n        }\n        return details;\n    }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":5,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"","fcontent":"<div data-cff-field=\"fieldname7\" class=\"symbol-table\"></div>","fBuild":{},"parent":"fieldname5"}],[{"title":"Cryptocurrency Market Data","description":"Calculate cryptocurrency prices with CoinGecko. Choose your preferred currency for accurate conversions.","formlayout":"top_aligned","formtemplate":"cp_cff_13","request_cost":"fieldname1","titletag":"H2","textalign":"center","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":".coingecko-table{max-height:500px;overflow:auto;}\n.coingecko-table table{width:100%;}\n.coingecko-table table thead th{padding:10px;position:sticky;top:0;background:#DADADA;}\n.coingecko-table table tbody td{cursor:pointer;padding:5px;}\n.coingecko-table table tbody tr:nth-child(even){background:#E9E9E9;}\n.coingecko-table table tbody td:not(:first-child){text-align:center;}\n.coingecko-table img{max-width:50px;}\n\n/* Symbol Table */\n.symbol-table table{width:100%;border-collapse:collapse;}\n.symbol-table table tbody td:not(:first-child){text-align:right;}\n.symbol-table table tbody td{border-top:1px solid #afafaf;padding:5px}\n.symbol-table table tbody td:first-child{font-weight:600;}"}]]