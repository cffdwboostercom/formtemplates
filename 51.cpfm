[[{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}}}},"_developerNotes":"Object with trucks information.","fcontent":"<script>\nwindow['availableTrucks'] = [\n    {name: \"Small Van\", maxWeight: 3000, cargoVolume: 300, fuelEfficiency: 20},\n    {name: \"Medium Truck\", maxWeight: 6000, cargoVolume: 600, fuelEfficiency: 15},\n    {name: \"Large Truck\", maxWeight: 10000, cargoVolume: 1000, fuelEfficiency: 10}\n];\n</script>","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname2","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname3","fieldname4"],"columns":"2","rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname6","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"HTML Content field to display the result.","fcontent":"<h2>Truck</h2>\n<p data-cff-field=\"fieldname5\" style=\"font-weight:600; font-size:18px;\"></p>","fBuild":{},"parent":""},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname5","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Truck","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"(function(){\n    const loadWeight = fieldname3;\n    const loadVolume = fieldname4;\nconsole.log(availableTrucks);\n    if( NOT(AND(loadWeight, loadVolume)) ) {\n        return '';\n    }\n\n    const suitableTrucks = availableTrucks.filter(truck => \n        truck.maxWeight >= loadWeight && truck.cargoVolume >= loadVolume\n    );\n    \n    if (suitableTrucks.length === 0) {\n        return \"No suitable truck found for the given load.\";\n    }\n    \n    /* Select the smallest suitable truck */\n    const selectedTruck = suitableTrucks.reduce((smallest, current) => \n        current.cargoVolume < smallest.cargoVolume ? current : smallest\n    );\n    \n    if(typeof selectedTruck === 'object') {\n        return `Selected truck: ${selectedTruck.name}<br>Max weight capacity: ${selectedTruck.maxWeight} pounds<br>Cargo volume: ${selectedTruck.cargoVolume} cubic feet<br>Fuel efficiency: ${selectedTruck.fuelEfficiency} mpg`;\n    }\n})()","min":"","max":"","suffix":"","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":true,"validate":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname3","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fnumber","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rule