ldname9), /* In centimeters */\n\t\tweight = SUM(fieldname7*0.45359237, fieldname11), /* In Kg */\n\t\tage    = fieldname2,\n\t\tgender = fieldname12;\n\t\n\tif (AND(height, weight, age )) {\n\t\tif ('male' == gender) {\n\t\t\treturn PREC(13.7516 * weight + 5.0033 * height - 6.755 * age + 66.473, 2, true);\n\t\t} else {\n\t\t\treturn PREC(9.5634 * weight + 1.8496 * height - 4.6756 * age + 655.0955, 2, true);\n\t\t}\n\t}\n\t\n\treturn '';\n})()","min":"","max":"","suffix":" kcal","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname13"},{"dependencies":[{"rule":"","complex":false,"fields":[""]}],"form_identifier":"","name":"fieldname14","fieldlayout":"default","shortlabel":"","index":23,"ftype":"fCalculated","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","advanced":{"css":{"label":{"label":"Field label","rules":{}},"input":{"label":"Calculated field","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"title":"Kilojoules","_developerNotes":"","predefined":"","required":false,"exclude":false,"size":"large","eq":"IF(fieldname1, PREC(fieldname1*4.1868, 2, true), '')","min":"","max":"","suffix":" kj","prefix":"","decimalsymbol":".","groupingsymbol":"","readonly":true,"currency":false,"noEvalIfManual":true,"formatDynamically":false,"dynamicEval":true,"hidefield":false,"validate":false,"fBuild":{},"parent":"fieldname13"}],[{"title":"Daily Calorie Intake","description":"","formlayout":"top_aligned","formtemplate":"cp_cff_13","textalign":"center","customstyles":"#fbuilder .pbNext,\n#fbuilder .pbPrevious,\n#fbuilder .pbSubmit,\n#fbuilder .cff-button-field input{\n\tbackground: #f92f60 !important;\n\tborder: 0 !important;\n}\n\n#fbuilder .pbNext:hover,\n#fbuilder .pbPrevious:hover,\n#fbuilder .pbSubmit:hover,\n#fbuilder .cff-button-field input:hover{\n\tbackground: #c5254c !important;\n\tborder: 0 !important;\n}\n\n#fbuilder .cff-switch-container input:checked+span.cff-switch{\n\tbackground:#f92f60 !important;\n}\n\n#fbuilder input[type=\"text\"]:focus,\n#fbuilder input[type=\"number\"]:focus,\n#fbuilder input[type=\"password\"]:focus,\n#fbuilder input[type=\"date\"]:focus,\n#fbuilder input[type=\"email\"]:focus,\n#fbuilder select:focus,\n#fbuilder textarea:focus{\n\toutline-color:#f92f60 !important;\n\tbox-shadow:none;\n}\n\n#fbuilder .pbreak>fieldset{border:0 !important;}\n#fbuilder .pbreak>fieldset>legend{\n\tborder:0 !important;\n\tborder-bottom:5px dotted #f92f60 !important;\n\tborder-radius:0 !important;\n\twidth: 50%;\n}\n#fbuilder .pbreak.pb1>fieldset>legend{\n\tborder:0 !important;\n\tborder-bottom:5px dotted #f92f60 !important;\n\tborder-radius:0 !important;\n\twidth: 100%;\n}\n\n#fbuilder .cff-calculated-field input{ font-weight:bold !important; }","titletag":"H2","headertextcolor":"","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade"}]]