[[{"form_identifier":"","name":"fieldname5","fieldlayout":"default","shortlabel":"","index":0,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":true,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"Resources","allowscript":1,"fcontent":"<script>\nimport('https://cdn.jsdelivr.net/npm/@xenova/transformers@2.6.1').then(function (module) {\n    const {\n        pipeline\n    } = module;\n    let fbuilderjQuery = window['fbuilderjQuery'];\n\n    // State\n    let translator = null;\n    let isTranslating = false;\n\n    function showSpinner() {\n        if (fbuilderjQuery('.cff-processing-form').length) {\n            fbuilderjQuery('.cff-processing-form').show();\n        } else {\n            fbuilderjQuery('<div class=\"cff-processing-form\"></div>').prependTo(fbuilderjQuery('#fbuilder'));\n        }\n    }\n\n    function hideSpinner() {\n        fbuilderjQuery('.cff-processing-form').hide();\n    }\n\n    // Initialize the translator\n    window['initCFFTranslator'] = async function () {\n        try {\n            showSpinner();\n            let _status = fbuilderjQuery('#model-status');\n            _status.text('Loading translation model...');\n            // Load the translation pipeline with a smaller model for faster loading\n            translator = await pipeline('translation', 'Xenova/nllb-200-distilled-600M');\n            _status.text('Model loaded successfully!');\n        } catch (error) {\n            console.error('Error loading model:', error);\n            _status.text(`Error loading model: ${error.message}`);\n            _status.addClass('model-status-error');\n        } finally {\n            hideSpinner();\n        }\n    };\n\n    // Translate text\n    window['translateText'] = async function (fromLang, toLang, text, targetField) {\n        let output = '';\n        if (!text || !translator || isTranslating)\n            return;\n        showSpinner();\n        isTranslating = true;\n        setTimeout(async function () {\n            try {\n                const result = await translator(text, {\n                    src_lang: fromLang,\n                    tgt_lang: toLang,\n                });\n                output = result[0].translation_text;\n                hideSpinner();\n            } catch (error) {\n                console.error('Translation error:', error);\n                output = 'Translation error occurred. Please try again.';\n                hideSpinner();\n            } finally {\n                isTranslating = false;\n                hideSpinner();\n            }\n            targetField.setVal(output);\n        }, 10);\n    };\n\n}).catch(function (err) {\n    console.error('Module loading error:', err);\n});\n\nfbuilderjQuery(document).on('formReady', function () {\n    function check() {\n        if (typeof initCFFTranslator == 'undefined') {\n            setTimeout(check, 50);\n        } else {\n            initCFFTranslator();\n        }\n    };\n    check();\n});\n</script>","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname1","fieldlayout":"default","shortlabel":"","index":1,"ftype":"fhtml","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"_developerNotes":"Loading model message","allowscript":0,"fcontent":"<p id=\"model-status\" class=\"model-status\">Initializing translator...</p>","fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname7","fieldlayout":"default","shortlabel":"","index":2,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname8","fieldname10","fieldname9"],"columns":1,"align":"bottom","rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname8","fieldlayout":"default","shortlabel":"","index":3,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"col-sm-5","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"dropdown":{"label":"Dropdown","rules":{}}}},"title":"Source Language","size":"large","required":false,"exclude":false,"accept_html":false,"toSubmit":"text","merge":0,"choiceSelected":"","select2":false,"multiple":false,"first_choice":false,"first_choice_text":"","vChoices":1,"showDep":false,"choices":["English","French","Spanish","German","Italian","Portuguese","Russian","Chinese","Japanese"],"optgroup":[false,false,false,false,false,false,false,false,false],"choicesVal":["eng_Latn","fra_Latn","spa_Latn","deu_Latn","ita_Latn","por_Latn","rus_Cyrl","zho_Hans","jpn_Jpan"],"choicesDep":[[],[],[],[],[],[],[],[],[]],"fBuild":{},"parent":"fieldname7"},{"form_identifier":"","name":"fieldname10","fieldlayout":"default","shortlabel":"","index":4,"ftype":"fButton","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"swap-btn col-sm-2","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"button":{"label":"Button","rules":{"margin-left":"50%","transform":"translatex(-50%)","background":"#999999","border":"0","color":"white"}},"button_hover":{"label":"Button hover","rules":{"background":"#666666"}}}},"sType":"button","sValue":"Swap","sOnclick":"let L1 = getField('fieldname8', this.form);\nlet L2 = getField('fieldname9', this.form);\nlet T1 = getField('fieldname12', this.form);\nlet T2 = getField('fieldname13', this.form);\n\nlet tmp = L1.val(false, true);\nL1.setVal(L2.val(false, true));\nL2.setVal(tmp);\n\ntmp = T1.val(true, true);\nT1.setVal(T2.val(true, true));\nT2.setVal(tmp);\n","sOnmousedown":"","sLoading":false,"sMultipage":false,"fBuild":{},"parent":"fieldname7"},{"form_identifier":"","name":"fieldname9","fieldlayout":"default","shortlabel":"","index":5,"ftype":"fdropdown","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"col-sm-5","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"dropdown":{"label":"Dropdown","rules":{}}}},"title":"Target Language","size":"large","required":false,"exclude":false,"accept_html":false,"toSubmit":"text","merge":0,"choiceSelected":"","select2":false,"multiple":false,"first_choice":false,"first_choice_text":"","vChoices":1,"showDep":false,"choices":["English","French","Spanish","German","Italian","Portuguese","Russian","Chinese","Japanese"],"optgroup":[false,false,false,false,false,false,false,false,false],"choicesVal":["eng_Latn","fra_Latn","spa_Latn","deu_Latn","ita_Latn","por_Latn","rus_Cyrl","zho_Hans","jpn_Jpan"],"choicesDep":[[],[],[],[],[],[],[],[],[]],"fBuild":{},"parent":"fieldname7"},{"form_identifier":"","name":"fieldname11","fieldlayout":"default","shortlabel":"","index":6,"ftype":"fdiv","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}}}},"fields":["fieldname12","fieldname13"],"columns":"2","align":"top","rearrange":0,"title":"div","_developerNotes":"","collapsed":false,"fBuild":{},"parent":""},{"form_identifier":"","name":"fieldname12","fieldlayout":"default","shortlabel":"","index":7,"ftype":"ftextarea","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"textarea":{"label":"Text area","rules":{}}}},"title":"Source Text","autocomplete":"off","predefined":"Enter text to translate...","predefinedClick":true,"required":false,"exclude":false,"accept_html":false,"readonly":false,"size":"large","minlength":"","maxlength":"","rows":"6","fBuild":{},"parent":"fieldname11"},{"form_identifier":"","name":"fieldname13","fieldlayout":"default","shortlabel":"","index":8,"ftype":"ftextarea","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"textarea":{"label":"Text area","rules":{}}}},"title":"Translated Text","autocomplete":"off","predefined":"Translation will appear here...","predefinedClick":true,"required":false,"exclude":false,"accept_html":false,"readonly":false,"size":"large","minlength":"","maxlength":"","rows":"6","fBuild":{},"parent":"fieldname11"},{"form_identifier":"","name":"fieldname14","fieldlayout":"default","shortlabel":"","index":9,"ftype":"fButton","userhelp":"","audiotutorial":"","userhelpTooltip":false,"tooltipIcon":false,"csslayout":"","hidefield":false,"advanced":{"css":{"container":{"label":"Field container div tag","rules":{"text-align":"center"}},"label":{"label":"Field label","rules":{}},"input":{"label":"Input tag","rules":{}},"help":{"label":"Instructions for users","rules":{}},"button":{"label":"Button","rules":{}},"button_hover":{"label":"Button hover","rules":{}}}},"sType":"button","sValue":"Translate","sOnclick":"translateText(\ngetField('fieldname8', this.form).val(true, true), \ngetField('fieldname9', this.form).val(true, true), \ngetField('fieldname12', this.form).val(true, true),\ngetField('fieldname13', this.form) \n);","sOnmousedown":"","sLoading":false,"sMultipage":false,"fBuild":{},"parent":""}],[{"title":"AI - Language Translator","titletag":"H2","textalign":"center","headertextcolor":"","description":"The form uses the AI for translating the text, it takes some time loading the model because does the inference in the browser without calling server-side code.","formlayout":"top_aligned","formtemplate":"cp_cff_13","evalequations":1,"evalequations_delay":0,"evalequationsevent":2,"direction":"ltr","loading_animation":0,"autocomplete":1,"persistence":0,"animate_form":0,"animation_effect":"fade","customstyles":"#fbuilder .model-status {\n\ttext-align: center;\n  margin: 0;\n  font-size: 16px;\n  color: #3498db;\n}\n#fbuilder .model-status-error {\n\tcolor:red;\n}\t\n","request_cost":"fieldname8","advanced":{"css":{"title":{"label":"Form title","rules":{}},"description":{"label":"Form description","rules":{}},"form":{"label":"Form area","rules":{}},"buttons":{"label":"Form context buttons (Next page, Previous page, Submit)","rules":{}},"buttons_hover":{"label":"Form context buttons hover","rules":{}},"error_bubble":{"label":"Error bubbles","rules":{}},"error_bubble_arrow":{"label":"Error bubble arrow","rules":{"border-bottom-color":""},"restrict":true}}}}]]